# Production Environment Variables for Flora Backend
# Copy this to .env on your production server and fill in the actual values

# === Application Settings ===
APP_NAME=Flora
DEBUG=False
# Generate a secure secret key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY

# === Database Settings ===
# Replace YOUR_DB_PASSWORD with the password you set in MongoDB setup
MONGODB_URL=mongodb://flora_user:YOUR_DB_PASSWORD@localhost:27017/flora_db?authSource=flora_db
MONGODB_DB_NAME=flora_db

# === AI Settings ===
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_ACTUAL_GEMINI_API_KEY

# === CORS Settings ===
# Add your actual domain (with https)
CORS_ORIGINS=https://flora.io.vn,https://www.flora.io.vn

# === Storage Settings ===
AUDIO_STORAGE_PATH=/var/www/flora/audio

# === Optional Settings ===
# LOG_LEVEL=INFO
# MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

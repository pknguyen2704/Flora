# Production Environment Variables
# Copy this to .env on your server and fill in the values

# App
APP_NAME=Flora
SECRET_KEY=your_generate_secret_key_here

# Database
MONGODB_DB_NAME=flora_db

# AI
GEMINI_API_KEY=your_gemini_api_key_here

# CORS
# Set this to your domain, e.g., http://yourdomain.com
CORS_ORIGINS=http://localhost,http://yourdomain.com
